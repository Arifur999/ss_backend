// Sales domain: sales, items, payments, deliveries, customer payments,
// FIFO cost layers.

model Sale {
  id               String         @id @default(uuid())
  owner_id         String
  invoice_no       String
  date             DateTime       @default(now()) @db.Date
  customer_id      String?
  customer_name    String
  customer_phone   String         @default("")
  customer_address String         @default("")
  subtotal         Decimal        @default(0) @db.Decimal(15, 2)
  discount_amount  Decimal        @default(0) @db.Decimal(15, 2)
  net_amount       Decimal        @default(0) @db.Decimal(15, 2)
  paid_amount      Decimal        @default(0) @db.Decimal(15, 2)
  due_amount       Decimal        @default(0) @db.Decimal(15, 2)
  account_id       String?
  account_name     String         @default("")
  branch_id        String?
  notes            String         @default("")
  status           SaleStatus     @default(completed)
  delivery_status  DeliveryStatus @default(pending)
  deleted_at       DateTime?
  deleted_by       String?
  created_by       String?
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt

  customer          Customer?           @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  sale_items        SaleItem[]
  sale_payments     SalePayment[]
  sale_deliveries   SaleDelivery[]
  customer_payments CustomerPayment[]
  cost_layers       SaleItemCostLayer[]

  @@unique([owner_id, invoice_no])
  @@index([owner_id])
  @@index([date])
  @@index([customer_id])
  @@index([delivery_status])
  @@map("sales")
}

model SaleItem {
  id            String   @id @default(uuid())
  owner_id      String
  sale_id       String
  product_id    String?
  product_code  String
  product_name  String
  selling_price Decimal  @default(0) @db.Decimal(15, 2)
  discount_pct  Decimal  @default(0) @db.Decimal(5, 2)
  actual_price  Decimal  @default(0) @db.Decimal(15, 2)
  qty           Int      @default(1)
  total_amount  Decimal  @default(0) @db.Decimal(15, 2)
  cost_price    Decimal  @default(0) @db.Decimal(15, 2)
  delivered_qty Int      @default(0)
  created_at    DateTime @default(now())

  sale            Sale                @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  product         Product?            @relation(fields: [product_id], references: [id], onDelete: Restrict)
  sale_deliveries SaleDelivery[]
  cost_layers     SaleItemCostLayer[]

  @@index([owner_id])
  @@index([sale_id])
  @@map("sale_items")
}

model SalePayment {
  id            String   @id @default(uuid())
  owner_id      String
  sale_id       String
  invoice_no    String   @default("")
  date          DateTime @default(now()) @db.Date
  customer_id   String?
  customer_name String   @default("")
  account_id    String?
  account_name  String   @default("")
  amount        Decimal  @default(0) @db.Decimal(15, 2)
  created_by    String?
  created_at    DateTime @default(now())

  sale     Sale      @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  account  Account?  @relation(fields: [account_id], references: [id], onDelete: Restrict)

  @@index([owner_id])
  @@index([sale_id])
  @@map("sale_payments")
}

model SaleDelivery {
  id            String   @id @default(uuid())
  owner_id      String
  sale_id       String
  sale_item_id  String
  delivery_date DateTime @default(now()) @db.Date
  delivered_qty Int      @default(0)
  delivered_by  String   @default("")
  branch_id     String?
  notes         String   @default("")
  created_by    String?
  created_at    DateTime @default(now())

  sale      Sale     @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  sale_item SaleItem @relation(fields: [sale_item_id], references: [id], onDelete: Cascade)

  @@index([owner_id])
  @@index([sale_id])
  @@index([delivery_date])
  @@map("sale_deliveries")
}

model CustomerPayment {
  id            String    @id @default(uuid())
  owner_id      String
  date          DateTime  @default(now()) @db.Date
  customer_id   String?
  customer_name String
  sale_id       String?
  invoice_no    String    @default("")
  amount        Decimal   @default(0) @db.Decimal(15, 2)
  account_id    String?
  account_name  String
  notes         String    @default("")
  deleted_at    DateTime?
  deleted_by    String?
  created_by    String?
  created_at    DateTime  @default(now())

  customer Customer? @relation(fields: [customer_id], references: [id], onDelete: Restrict)
  sale     Sale?     @relation(fields: [sale_id], references: [id], onDelete: SetNull)
  account  Account?  @relation(fields: [account_id], references: [id], onDelete: Restrict)

  @@index([owner_id])
  @@index([customer_id])
  @@map("customer_payments")
}

model SaleItemCostLayer {
  id                 String              @id @default(uuid())
  owner_id           String
  sale_id            String?
  sale_item_id       String?
  product_id         String?
  inventory_batch_id String?
  source_type        CostLayerSourceType @default(fifo)
  qty                Int                 @default(0)
  dp_price           Decimal             @default(0) @db.Decimal(15, 2)
  cost_amount        Decimal             @default(0) @db.Decimal(15, 2)
  created_by         String?
  created_at         DateTime            @default(now())

  sale            Sale?           @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  sale_item       SaleItem?       @relation(fields: [sale_item_id], references: [id], onDelete: Cascade)
  product         Product?        @relation(fields: [product_id], references: [id], onDelete: SetNull)
  inventory_batch InventoryBatch? @relation(fields: [inventory_batch_id], references: [id], onDelete: SetNull)

  @@index([owner_id])
  @@index([sale_item_id])
  @@index([product_id])
  @@map("sale_item_cost_layers")
}
