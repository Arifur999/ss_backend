// Products, purchases, inventory (incl. FIFO batches) domain.

model Product {
  id            String    @id @default(uuid())
  owner_id      String
  product_code  String
  name          String
  image_url     String    @default("")
  supplier_id   String?
  selling_price Decimal   @default(0) @db.Decimal(15, 2)
  cost_price    Decimal   @default(0) @db.Decimal(15, 2)
  discount      Decimal   @default(0) @db.Decimal(15, 2)
  size          String?
  weight        String?
  opening_qty   Int       @default(0)
  is_active     Boolean   @default(true)
  deleted_at    DateTime?
  deleted_by    String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  supplier              Supplier?           @relation(fields: [supplier_id], references: [id], onDelete: SetNull)
  purchase_items        PurchaseItem[]
  inventory             Inventory[]
  inventory_history     InventoryHistory[]
  inventory_batches     InventoryBatch[]
  sale_items            SaleItem[]
  sale_item_cost_layers SaleItemCostLayer[]

  @@unique([owner_id, product_code])
  @@index([owner_id])
  @@map("products")
}

model Purchase {
  id              String         @id @default(uuid())
  owner_id        String
  si_no           String
  supplier_id     String?
  supplier_name   String
  date            DateTime       @default(now()) @db.Date
  total_amount    Decimal        @default(0) @db.Decimal(15, 2)
  discount_amount Decimal        @default(0) @db.Decimal(15, 2)
  net_amount      Decimal        @default(0) @db.Decimal(15, 2)
  paid_amount     Decimal        @default(0) @db.Decimal(15, 2)
  due_amount      Decimal        @default(0) @db.Decimal(15, 2)
  shipping_status ShippingStatus @default(pending)
  notes           String         @default("")
  branch_id       String?
  deleted_at      DateTime?
  deleted_by      String?
  created_by      String?
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  supplier          Supplier?         @relation(fields: [supplier_id], references: [id], onDelete: Restrict)
  purchase_items    PurchaseItem[]
  purchase_receives PurchaseReceive[]
  supplier_payments SupplierPayment[]

  @@unique([owner_id, si_no])
  @@index([owner_id])
  @@index([date])
  @@index([supplier_id])
  @@map("purchases")
}

model PurchaseItem {
  id           String   @id @default(uuid())
  owner_id     String
  purchase_id  String
  product_id   String?
  product_code String
  product_name String
  dp_price     Decimal  @default(0) @db.Decimal(15, 2)
  discount_pct Decimal  @default(0) @db.Decimal(5, 2)
  actual_dp    Decimal  @default(0) @db.Decimal(15, 2)
  qty          Int      @default(1)
  total_amount Decimal  @default(0) @db.Decimal(15, 2)
  sp_pct       Decimal  @default(0) @db.Decimal(5, 2)
  sp_amount    Decimal  @default(0) @db.Decimal(15, 2)
  received_qty Int      @default(0)
  created_at   DateTime @default(now())

  purchase          Purchase          @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
  product           Product?          @relation(fields: [product_id], references: [id], onDelete: Restrict)
  purchase_receives PurchaseReceive[]
  inventory_batches InventoryBatch[]

  @@index([owner_id])
  @@index([purchase_id])
  @@map("purchase_items")
}

model PurchaseReceive {
  id               String           @id @default(uuid())
  owner_id         String
  purchase_id      String
  purchase_item_id String
  receive_date     DateTime         @default(now()) @db.Date
  receiver_name    String
  received_qty     Int              @default(0)
  condition        ReceiveCondition @default(good)
  branch_id        String?
  notes            String           @default("")
  created_by       String?
  created_at       DateTime         @default(now())

  purchase          Purchase         @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
  purchase_item     PurchaseItem     @relation(fields: [purchase_item_id], references: [id], onDelete: Cascade)
  inventory_batches InventoryBatch[]

  @@index([owner_id])
  @@index([purchase_id])
  @@map("purchase_receives")
}

model SupplierPayment {
  id             String    @id @default(uuid())
  owner_id       String
  date           DateTime  @default(now()) @db.Date
  supplier_id    String?
  supplier_name  String
  purchase_id    String?
  purchase_si_no String    @default("")
  amount         Decimal   @default(0) @db.Decimal(15, 2)
  account_id     String?
  account_name   String
  notes          String    @default("")
  deleted_at     DateTime?
  deleted_by     String?
  created_by     String?
  created_at     DateTime  @default(now())

  supplier Supplier? @relation(fields: [supplier_id], references: [id], onDelete: Restrict)
  purchase Purchase? @relation(fields: [purchase_id], references: [id], onDelete: SetNull)
  account  Account?  @relation(fields: [account_id], references: [id], onDelete: Restrict)

  @@index([owner_id])
  @@index([supplier_id])
  @@map("supplier_payments")
}

model Inventory {
  id            String   @id @default(uuid())
  owner_id      String
  product_id    String
  branch_id     String?
  available_qty Int      @default(0)
  upcoming_qty  Int      @default(0)
  dp_price      Decimal? @db.Decimal(15, 2)
  updated_at    DateTime @updatedAt

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([owner_id, product_id])
  @@index([product_id])
  @@map("inventory")
}

model InventoryHistory {
  id             String              @id @default(uuid())
  owner_id       String
  product_id     String?
  product_name   String
  branch_id      String?
  branch_name    String              @default("")
  change_type    InventoryChangeType
  qty_change     Int
  qty_before     Int                 @default(0)
  qty_after      Int                 @default(0)
  reference_id   String?
  reference_type String              @default("")
  notes          String              @default("")
  created_by     String?
  created_at     DateTime            @default(now())

  product Product? @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([owner_id])
  @@index([product_id])
  @@map("inventory_history")
}

model InventoryBatch {
  id                  String          @id @default(uuid())
  owner_id            String
  product_id          String
  purchase_item_id    String?
  purchase_receive_id String?
  source_type         BatchSourceType @default(purchase_receive)
  received_qty        Int             @default(0)
  remaining_qty       Int             @default(0)
  dp_price            Decimal         @default(0) @db.Decimal(15, 2)
  mrp_price           Decimal         @default(0) @db.Decimal(15, 2)
  received_date       DateTime        @default(now()) @db.Date
  created_by          String?
  created_at          DateTime        @default(now())

  product          Product             @relation(fields: [product_id], references: [id], onDelete: Cascade)
  purchase_item    PurchaseItem?       @relation(fields: [purchase_item_id], references: [id], onDelete: SetNull)
  purchase_receive PurchaseReceive?    @relation(fields: [purchase_receive_id], references: [id], onDelete: SetNull)
  cost_layers      SaleItemCostLayer[]

  @@index([owner_id])
  @@index([product_id, received_date])
  @@map("inventory_batches")
}
