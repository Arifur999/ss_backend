NODE_ENV=development
PORT=5000

# Local PostgreSQL
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/furniture_business"

# JWT
ACCESS_TOKEN_SECRET=change_this_access_secret
REFRESH_TOKEN_SECRET=change_this_refresh_secret
ACCESS_TOKEN_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN=7d

# Frontend origin (CORS)
FRONTEND_URL=http://localhost:5173

# Super Admin seed
SUPER_ADMIN_EMAIL=hatim3827@gmail.com
SUPER_ADMIN_PASSWORD=hatim@3827

# Email sender (OTP verification mails)
# Option A (preferred in production/on Railway - see RESEND_* below): most
# cloud hosts block outbound SMTP to fight spam, so direct SMTP/OAuth2 sends
# can hang until they time out. Resend sends over plain HTTPS instead, so it
# works from anywhere.
# Option B: Google OAuth2 - fill the GOOGLE_* block below (fine for local dev).
# Option C: Gmail App Password - fill the SMTP_* block below (fine for local dev).
# None configured -> OTP prints to the server console (dev mode).

# Resend (https://resend.com) - free tier is 3,000 emails/month.
# FROM_EMAIL must be on a domain you've verified in Resend, or leave it as
# the default onboarding@resend.dev for quick testing (limited deliverability).
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

EMAIL_SENDER_SMTP_HOST=smtp.gmail.com
EMAIL_SENDER_SMTP_PORT=465
EMAIL_SENDER_SMTP_USER=
EMAIL_SENDER_SMTP_PASS=
EMAIL_SENDER_SMTP_FROM=

# Google OAuth2 for Gmail sending.
# 1) Create an OAuth client (Web application) in Google Cloud Console
# 2) Add redirect URI: http://localhost:5050/oauth2/callback
# 3) Run `npm run google:token`, approve with the Gmail account, copy the token
GOOGLE_MAIL_USER=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================================
# bKash Payment Gateway (Tokenized Checkout)
# Get sandbox credentials from the bKash developer portal;
# production credentials come with your bKash merchant account.
# ============================================================
# Which credential set to use: sandbox | production
BKASH_MODE=sandbox

# --- Sandbox ---
BKASH_SANDBOX_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_SANDBOX_APP_KEY=
BKASH_SANDBOX_APP_SECRET=
BKASH_SANDBOX_USERNAME=
BKASH_SANDBOX_PASSWORD=

# --- Production (merchant) ---
BKASH_PROD_BASE_URL=https://tokenized.pay.bka.sh/v1.2.0-beta
BKASH_PROD_APP_KEY=
BKASH_PROD_APP_SECRET=
BKASH_PROD_USERNAME=
BKASH_PROD_PASSWORD=

# Redirect URL bKash calls after the customer approves/cancels the payment
BKASH_CALLBACK_URL=http://localhost:5000/api/v1/payments/bkash/callback
