NODE_ENV=development
PORT=5000

# Local PostgreSQL
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/furniture_business"

# JWT
ACCESS_TOKEN_SECRET=change_this_access_secret
REFRESH_TOKEN_SECRET=change_this_refresh_secret
ACCESS_TOKEN_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN=7d

# Frontend origin (CORS)
FRONTEND_URL=http://localhost:5173

# Super Admin seed
SUPER_ADMIN_EMAIL=hatim3827@gmail.com
SUPER_ADMIN_PASSWORD=hatim@3827

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================================
# bKash Payment Gateway (Tokenized Checkout)
# Get sandbox credentials from the bKash developer portal;
# production credentials come with your bKash merchant account.
# ============================================================
# Which credential set to use: sandbox | production
BKASH_MODE=sandbox

# --- Sandbox ---
BKASH_SANDBOX_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_SANDBOX_APP_KEY=
BKASH_SANDBOX_APP_SECRET=
BKASH_SANDBOX_USERNAME=
BKASH_SANDBOX_PASSWORD=

# --- Production (merchant) ---
BKASH_PROD_BASE_URL=https://tokenized.pay.bka.sh/v1.2.0-beta
BKASH_PROD_APP_KEY=
BKASH_PROD_APP_SECRET=
BKASH_PROD_USERNAME=
BKASH_PROD_PASSWORD=

# Redirect URL bKash calls after the customer approves/cancels the payment
BKASH_CALLBACK_URL=http://localhost:5000/api/v1/payments/bkash/callback
